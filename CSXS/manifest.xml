<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.theo.reverse"
    ExtensionBundleVersion="1.1.0" ExtensionBundleName="THEO REVERSE"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.theo.reverse.panel" Version="1.1.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- AEFT = After Effects. [22.0,99.9] covers AE 2022 through 2026+. -->
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <!-- Min CEP runtime; loads on CEP 11 (AE 2024/25) and CEP 12 (AE 2026). -->
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.theo.reverse.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/engine.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>THEO REVERSE</Menu>
          <Geometry>
            <Size><Height>600</Height><Width>380</Width></Size>
            <MinSize><Height>360</Height><Width>320</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
